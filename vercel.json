{
  "version": 2,
  "builds": [
    { "src": "index.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "index.html" },
    { "src": "/api/index", "dest": "index.py" }
  ],
  "crons": [
    {
      "path": "/api/index",
      "schedule": "0 0 * * *"
    }
  ]
}